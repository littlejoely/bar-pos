# 登录与权限数据库。默认无需设置，将使用 backend/instance/auth.db。
# POS_AUTH_DATABASE_URL=sqlite:////absolute/path/to/pos-bar/backend/instance/auth.db
# POS_AUTH_DATABASE_PATH=/absolute/path/to/pos-bar/backend/instance/auth.db

# 本地 HTTP 保持 false；生产 HTTPS 环境必须设为 true。
POS_COOKIE_SECURE=false

# 仅当服务位于已正确配置的可信反向代理后方时开启，开启后读取 X-Forwarded-For。
POS_TRUST_PROXY=false

# 会话、锁屏与登录风控。
POS_SESSION_HOURS=12
POS_MAX_ACTIVE_SESSIONS=2
POS_IDLE_LOCK_MINUTES=30
POS_LOGIN_FAILURE_LIMIT=5
POS_LOGIN_LOCK_MINUTES=15
POS_LOGIN_RATE_LIMIT=10
POS_UNLOCK_RATE_LIMIT=5

# 作品集访客演示账号。访客可查看系统信息，只能修改本人创建的数据及其后续事件。
POS_DEMO_GUEST_ENABLED=true
POS_DEMO_GUEST_USERNAME=visitor
POS_DEMO_GUEST_PASSWORD=Visitor@2026
POS_DEMO_GUEST_SHORT_ACCOUNT=guest
POS_DEMO_GUEST_SHORT_PASSWORD=2026

# 仅开发环境跨域需要；生产前后端同源时不会触发 CORS。
POS_CORS_ORIGINS=http://localhost:27778,http://127.0.0.1:27778
